cat > .gitignore << EOF
# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.so
*.egg
*.egg-info/
dist/
build/

# Virtual environments
.venv/
venv/
ENV/
env/

# Database
*.db
*.sqlite
*.sqlite3

# Environment variables
.env
.env.local

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Logs
*.log

# Jupyter
.ipynb_checkpoints/
*.ipynb

# OS junk
.DS_Store
Thumbs.db

# Uploaded file cache (if any)
file_bytes_cache.pkl
EOF